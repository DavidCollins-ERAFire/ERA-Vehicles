# ===========================================================================
# ERA Fleet — environment configuration
# ===========================================================================
# Copy this file to ".env" and fill in the values:
#     cp .env.example .env
#
# Why ".env" (not ".env.local")? Next.js AND Prisma both read ".env"
# automatically, so a single file configures the whole app — no split config.
# (Next.js will still read ".env.local" too if you prefer to keep secrets
# separate; values there override ".env".)
#
# The app runs locally even before the Google/Slack values are filled in —
# those integrations simply no-op until configured, so you can boot it first
# and wire up credentials afterward.
# ===========================================================================

# --- Database (SQLite, local file) -----------------------------------------
# Path is resolved relative to the prisma/ folder, so this lands at
# prisma/database.sqlite. You normally never need to change this.
DATABASE_URL="file:./database.sqlite"

# --- NextAuth (login sessions) ---------------------------------------------
# The URL the app is served from. Localhost for dev; on a Pi/Mini PC use the
# machine's LAN address or hostname, e.g. http://192.168.1.50:3000
NEXTAUTH_URL="http://localhost:3000"
# A long random string used to sign session cookies. Generate one with:
#     openssl rand -base64 32
NEXTAUTH_SECRET="paste-a-long-random-string-here"

# --- Google OAuth (Single Sign-On) -----------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (type: Web application). Authorized redirect URI must be:
#     <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated corporate domains allowed to sign in. Leave BLANK to allow
# any Google account (not recommended for production).
#   e.g. ALLOWED_EMAIL_DOMAINS="erafire.com"
ALLOWED_EMAIL_DOMAINS="erafire.com"

# --- Google service account (Drive, Sheets, Gmail send) --------------------
# These workflows run without a logged-in user (e.g. the cron sweep), so they
# use a Google service account rather than the signed-in user's token.
# Create one in Cloud Console → IAM & Admin → Service Accounts, add a JSON key.
#
# Provide the key in ONE of two ways:
#   (A) Base64 of the whole JSON (handy for a single-line env value):
#         base64 -w0 service-account.json
#       then paste the result here:
GOOGLE_SERVICE_ACCOUNT_KEY=""
#   (B) …OR a path to the JSON file on disk (leave KEY blank if you use this):
GOOGLE_SERVICE_ACCOUNT_FILE=""

# The Gmail address that system emails are sent "from". For Gmail sending the
# service account needs domain-wide delegation authorized for this user.
GMAIL_SENDER="fleet@erafire.com"

# Google Drive folder ID that uploaded invoices/receipts are saved into.
# It's the long ID in the folder URL: drive.google.com/drive/folders/<THIS>
# Share that folder with the service account's email (…@…iam.gserviceaccount.com).
GOOGLE_DRIVE_INVOICE_FOLDER_ID=""

# Google Sheet ID the database mirrors into (Vehicles + Service Requests tabs).
# It's the long ID in the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
# Share the sheet with the service account's email as an Editor.
GOOGLE_SHEETS_ID=""

# --- Slack -----------------------------------------------------------------
# Incoming Webhook URL for the channel that gets fleet alerts.
# Slack → your app → Incoming Webhooks → Add New Webhook to Workspace.
SLACK_WEBHOOK_URL=""
# Bot token (starts with xoxb-) used for direct messages to drivers/supervisors.
# Slack → your app → OAuth & Permissions. Needs scopes: chat:write, im:write,
# users:read. Each User row needs their Slack member ID in the `slackId` field
# for DMs to reach them (channel webhook alerts work without it).
SLACK_BOT_TOKEN=""

# --- Maintenance sweep -----------------------------------------------------
# Shared secret protecting the /api/cron/maintenance endpoint. Generate with:
#     openssl rand -hex 16
CRON_SECRET="paste-a-random-string-here"
# Optional: where the cron runner should call the app. Defaults to NEXTAUTH_URL,
# then http://localhost:3000. Set only if those don't match the local server.
# CRON_TARGET_URL="http://localhost:3000"

# Average miles/day per vehicle, used to project oil-change timing between
# odometer readings (there's no live odometer feed). Tune to your fleet.
FLEET_AVG_MILES_PER_DAY="50"
