// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  password      String
  role          String     @default("DRIVER") // DRIVER, SUPERVISOR, MANAGER
  phone         String?
  driverId      String?
  isActive      Boolean    @default(true)

  driver        Driver?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([email])
}

model Driver {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName             String
  lastName              String
  driverLicense         String   @unique
  licenseExpiration     DateTime
  dateOfHire            DateTime
  phoneNumber           String
  emergencyContact      String?
  emergencyPhone        String?

  assignedVehicleId     String?
  assignedVehicle       Vehicle? @relation(fields: [assignedVehicleId], references: [id])

  currentStatus         String   @default("AVAILABLE") // AVAILABLE, ASSIGNED, ON_LEAVE
  safetyRating          Decimal  @db.Decimal(3, 2)
  accidentsCount        Int      @default(0)
  violationsCount       Int      @default(0)

  serviceRequests       ServiceRequest[]
  driverLogs            DriverLog[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([assignedVehicleId])
}

model Vehicle {
  id                    String   @id @default(cuid())
  unitNumber            String   @unique
  make                  String
  model                 String
  year                  Int
  vin                   String   @unique
  licensePlate          String   @unique
  
  mileage               Int      @default(0)
  lastServiceDate       DateTime?
  registrationExpire    DateTime?
  inspectionExpire      DateTime?
  insuranceExpire       DateTime?
  
  fuelType              String   @default("DIESEL") // DIESEL, GASOLINE, HYBRID, ELECTRIC
  vin2                  String?

  assignedDrivers       Driver[]
  serviceRequests       ServiceRequest[]
  maintenanceRecords    MaintenanceRecord[]
  scheduledMaintenance  ScheduledMaintenance[]
  driverLogs            DriverLog[]
  quarterlyReviews      QuarterlyReview[]
  reminders             Reminder[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([unitNumber])
}

model ServiceRequest {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  driverId              String
  driver                Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  title                 String
  description           String   @db.Text
  mileageReported       Int
  status                String   @default("PENDING") // PENDING, SCHEDULED, COMPLETE, CANCELLED
  
  reportedDate          DateTime @default(now())
  scheduledDate         DateTime?
  completedDate         DateTime?
  
  shop                  String?
  estimatedCost         Decimal? @db.Decimal(10, 2)
  actualCost            Decimal? @db.Decimal(10, 2)
  invoiceUrl            String?
  
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([vehicleId])
  @@index([driverId])
  @@index([status])
}

model DriverLog {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  driverId              String
  driver                Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  logDate               DateTime
  mileageStart          Int
  mileageEnd            Int
  duration              Int      // minutes
  
  logistics             String   @default("RIDING_WITH") // RIDING_WITH, SPARE_VEHICLE, OFFICE_DUTY
  destination           String?
  notes                 String?  @db.Text

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([vehicleId])
  @@index([driverId])
  @@index([logDate])
}

model QuarterlyReview {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  quarter               String   // "Q1", "Q2", "Q3", "Q4"
  year                  Int
  mileage               Int
  
  oilChangeNeeded       Boolean  @default(false)
  tireRotationNeeded    Boolean  @default(false)
  inspectionNeeded      Boolean  @default(false)
  registrationNeeded    Boolean  @default(false)
  emissionsNeeded       Boolean  @default(false)
  insuranceNeeded       Boolean  @default(false)
  
  notes                 String?  @db.Text
  reviewedDate          DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([vehicleId, quarter, year])
  @@index([vehicleId])
}

model Reminder {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  type                  String   // OIL_CHANGE, REGISTRATION, INSPECTION, EMISSIONS, INSURANCE, QUARTERLY_REVIEW
  dueDate               DateTime
  dueMileage            Int?
  
  isCompleted           Boolean  @default(false)
  completedDate         DateTime?
  
  notes                 String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([vehicleId])
  @@index([dueDate])
}

model MaintenanceRecord {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  type                  String   // "Oil Change", "Tire Rotation", "Inspection", "Registration", "Emissions", "Insurance", "Repair", "Other"
  description           String   @db.Text
  mileageAtService      Int
  
  serviceDate           DateTime
  vendor                String?
  technician            String?
  
  cost                  Decimal  @db.Decimal(10, 2)
  invoiceUrl            String?
  
  nextDueDate           DateTime?
  nextDueMileage        Int?
  
  notes                 String?  @db.Text
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([vehicleId])
  @@index([serviceDate])
}

model ScheduledMaintenance {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  type                  String   // Oil Change, Inspection, etc.
  intervalMiles         Int?
  intervalMonths        Int?
  
  lastCompletedDate     DateTime?
  lastCompletedMileage  Int?
  
  nextDueDate           DateTime?
  nextDueMileage        Int?
  
  isActive              Boolean  @default(true)
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([vehicleId])
}

model MaintenanceTemplate {
  id                    String   @id @default(cuid())
  name                  String   @unique
  type                  String
  defaultCost           Decimal? @db.Decimal(10, 2)
  intervalMiles         Int?
  intervalMonths        Int?
  description           String?  @db.Text
  
  createdAt             DateTime @default(now())
}
